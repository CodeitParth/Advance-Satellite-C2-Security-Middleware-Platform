    "too_short":          { "packet_hex": "190000",    "expected_error": "TOO_SHORT" },
    "wrong_version":      { "packet_hex": "390EC00000011234",  "expected_error": "INVALID_VERSION" },
    "unknown_apid":       { "packet_hex": "1FFFC000000100ABCD", "expected_error": "UNKNOWN_APID" },
