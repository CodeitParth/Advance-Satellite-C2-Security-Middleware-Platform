{
  "_comment": "CCSDS Telecommand Packet Fixtures for SCSP MVP",
  "_format": "Each entry: apid (hex), packet_hex (valid CCSDS), expected parsed output, telemetry contexts for scoring",
  "_crc": "CRC-16-CCITT, polynomial 0x1021, init 0xFFFF, appended as final 2 bytes big-endian",
  "_header": "6 bytes: [version|type|apid 2B][seq_flags|seq_count 2B][data_length 2B], then secondary header (1B function code), then data, then CRC",

  "packets": {

    "REQUEST_TELEMETRY": {
      "apid": "0x100",
      "apid_int": 256,
      "subsystem": "TM",
      "function_code": "0x01",
      "description": "Request telemetry beacon from satellite",
      "packet_hex": "1900C0000000012A4B",
      "parameters": {},
      "expected_parse": {
        "success": true,
        "apid": 256,
        "subsystem": "TM",
        "command_type": "REQUEST_TELEMETRY",
        "sequence_count": 0,
        "crc_valid": true
      },
      "telemetry_contexts": {
        "nominal":        { "expected_tier": "LOW",    "expected_score_range": [0, 15] },
        "low_power":      { "expected_tier": "LOW",    "expected_score_range": [0, 20] },
        "critical_state": { "expected_tier": "LOW",    "expected_score_range": [0, 25] }
      }
    },

    "SET_BEACON_RATE": {
      "apid": "0x101",
