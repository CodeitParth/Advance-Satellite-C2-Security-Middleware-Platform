        "nominal":        { "expected_tier": "LOW",    "expected_score_range": [0, 20] },
        "low_power":      { "expected_tier": "LOW",    "expected_score_range": [5, 25] },
        "critical_state": { "expected_tier": "MEDIUM", "expected_score_range": [20, 40] }
      }
    },

